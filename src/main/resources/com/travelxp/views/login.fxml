<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<StackPane alignment="CENTER" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.travelxp.controllers.LoginController">
   <children>
      <VBox alignment="CENTER" maxWidth="400.0" spacing="20.0" styleClass="card">
         <children>
            <Label text="LOGIN" styleClass="title" />
            <VBox spacing="10.0">
               <children>
                  <Label text="Email" />
                  <TextField fx:id="emailField" promptText="Enter your email" />
               </children>
            </VBox>
            <VBox spacing="10.0">
               <children>
                  <Label text="Password" />
                  <PasswordField fx:id="passwordField" promptText="Enter your password" />
               </children>
            </VBox>
            <Button fx:id="loginButton" maxWidth="Infinity" onAction="#handleLogin" text="LOGIN" />
            <Button onAction="#handleRegisterRedirect" maxWidth="Infinity" styleClass="secondary-button" text="REGISTER" />
         </children>
         <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
         </padding>
      </VBox>
   </children>
</StackPane>
