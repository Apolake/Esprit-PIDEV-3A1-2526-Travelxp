<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.travelxp.controllers.CommentsViewController"
            stylesheets="@../../../style.css"
            style="-fx-background-color: #f9f9f9;">

    <top>
        <VBox spacing="10" style="-fx-padding: 20; -fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
            <VBox spacing="5" style="-fx-border-color: #e0e0e0; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-color: #f5f5f5; -fx-padding: 15;">
                <Label text="Feedback:" style="-fx-font-size: 12; -fx-text-fill: #666; -fx-font-weight: bold;"/>
                <Label fx:id="feedbackContentLabel"
                       wrapText="true"
                       style="-fx-font-size: 14; -fx-text-fill: #333;"/>
            </VBox>

            <HBox spacing="10" style="-fx-alignment: center-right;">
                <Button text="+ Add Comment"
                        onAction="#handleAddComment"
                        styleClass="button, primary-button"/>
            </HBox>
            <HBox spacing="6" style="-fx-alignment: center-left;">
                <Label text="Sort by:" />
                <ComboBox fx:id="commentSortCombo" prefWidth="120" />
                <Button text="Reset" onAction="#handleCommentReset" />
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="10" style="-fx-padding: 20;">
            <Label text="Comments:" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #333;"/>

            <ScrollPane fitToWidth="true" style="-fx-padding: 0; -fx-background-color: #f9f9f9;">
                <VBox fx:id="commentsContainer"
                      spacing="12"
                      style="-fx-padding: 5; -fx-background-color: #f9f9f9;"/>
            </ScrollPane>
        </VBox>
    </center>

</BorderPane>
