<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<StackPane alignment="CENTER" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.travelxp.controllers.ProfileController">
   <children>
      <VBox alignment="CENTER" maxWidth="600.0" spacing="20.0" styleClass="card">
         <children>
            <Label text="PROFILE" styleClass="title" />
            <ImageView fx:id="profileImageView" fitHeight="150.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true" />
            <VBox spacing="5.0" alignment="CENTER">
               <children>
                  <Label text="Username" style="-fx-font-weight: bold; -fx-text-fill: #C9A227;" />
                  <Label fx:id="usernameLabel" text="UsernameValue" />
               </children>
            </VBox>
            <VBox spacing="5.0" alignment="CENTER">
               <children>
                  <Label text="Email" style="-fx-font-weight: bold; -fx-text-fill: #C9A227;" />
                  <Label fx:id="emailLabel" text="EmailValue" />
               </children>
            </VBox>
            <VBox spacing="5.0" alignment="CENTER">
               <children>
                  <Label text="Birthday" style="-fx-font-weight: bold; -fx-text-fill: #C9A227;" />
                  <Label fx:id="birthdayLabel" text="BirthdayValue" />
               </children>
            </VBox>
            <VBox spacing="5.0" alignment="CENTER">
               <children>
                  <Label text="Bio" style="-fx-font-weight: bold; -fx-text-fill: #C9A227;" />
                  <Label fx:id="bioLabel" text="BioValue" wrapText="true" maxWidth="400.0" />
               </children>
            </VBox>
            <VBox spacing="5.0" alignment="CENTER">
               <children>
                  <Label text="Member Since" style="-fx-font-weight: bold; -fx-text-fill: #C9A227;" />
                  <Label fx:id="joinedLabel" text="JoinedValue" />
               </children>
            </VBox>
            <HBox spacing="10.0" alignment="CENTER">
               <children>
                  <Button onAction="#handleEditProfile" text="EDIT PROFILE" />
                  <Button onAction="#handleChangePassword" text="CHANGE PASSWORD" />
               </children>
            </HBox>
            <HBox spacing="10.0" alignment="CENTER">
               <children>
                  <Button onAction="#handleDeleteAccount" style="-fx-background-color: #d32f2f;" text="DELETE ACCOUNT" />
                  <Button onAction="#handleLogout" styleClass="secondary-button" text="LOGOUT" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
         </padding>
      </VBox>
   </children>
</StackPane>
