<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.travelxp.controllers.PropertyController" stylesheets="@../../../style.css" styleClass="root">
   <top>
      <HBox spacing="20" alignment="CENTER_LEFT" styleClass="top-bar">
         <padding>
            <Insets top="10" right="20" bottom="10" left="20"/>
         </padding>
         <children>
            <Button text="Back" onAction="#handleBack" styleClass="button, secondary-button"/>
            <Label text="Property Management" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
         </children>
      </HBox>
   </top>
   <center>
      <VBox spacing="20">
         <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
         </padding>
         <children>
            <GridPane fx:id="adminForm" hgap="10" vgap="10" styleClass="card">
               <padding>
                  <Insets top="15" right="15" bottom="15" left="15"/>
               </padding>
               <children>
                  <Label text="Owner ID:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                  <TextField fx:id="ownerIdField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                  
                  <Label text="Title:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                  <TextField fx:id="titleField" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                  
                  <Label text="Type:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                  <TextField fx:id="propertyTypeField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                  
                  <Label text="Address:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                  <TextField fx:id="addressField" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                  
                  <Label text="City:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                  <TextField fx:id="cityField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                  
                  <Label text="Country:" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                  <TextField fx:id="countryField" GridPane.columnIndex="3" GridPane.rowIndex="2"/>
                  
                  <Label text="Price:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                  <TextField fx:id="priceField" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                  
                  <Label text="Max Guests:" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
                  <TextField fx:id="maxGuestsField" GridPane.columnIndex="3" GridPane.rowIndex="3"/>

                  <Label text="Bedrooms:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                  <TextField fx:id="bedroomsField" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                  <Label text="Bathrooms:" GridPane.columnIndex="2" GridPane.rowIndex="4"/>
                  <TextField fx:id="bathroomsField" GridPane.columnIndex="3" GridPane.rowIndex="4"/>

                  <Label text="Images:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                  <HBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="5">
                     <children>
                        <TextField fx:id="imagesField" HBox.hgrow="ALWAYS" editable="false"/>
                        <Button text="..." onAction="#handleChooseImage" styleClass="button"/>
                     </children>
                  </HBox>

                  <Label text="Description:" GridPane.columnIndex="2" GridPane.rowIndex="5"/>
                  <TextField fx:id="descriptionField" GridPane.columnIndex="3" GridPane.rowIndex="5"/>
                  
                  <CheckBox fx:id="isActiveCheck" text="Is Active" selected="true" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
                  
                  <HBox spacing="10" GridPane.columnIndex="3" GridPane.rowIndex="6" alignment="CENTER_RIGHT">
                     <children>
                        <Button text="Clear" onAction="#handleClearForm" styleClass="button"/>
                        <Button text="Add" onAction="#handleAddProperty" styleClass="button, primary-button"/>
                        <Button text="Update" onAction="#handleUpdateProperty" styleClass="button, secondary-button"/>
                        <Button text="Delete" onAction="#handleDeleteProperty" styleClass="button, danger-button"/>
                     </children>
                  </HBox>
               </children>
            </GridPane>
            
            <TableView fx:id="propertyTable" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="idCol" text="ID" prefWidth="50"/>
                  <TableColumn fx:id="ownerIdCol" text="Owner" prefWidth="60"/>
                  <TableColumn fx:id="titleCol" text="Title" prefWidth="120"/>
                  <TableColumn fx:id="descriptionCol" text="Description" prefWidth="100"/>
                  <TableColumn fx:id="propertyTypeCol" text="Type" prefWidth="80"/>
                  <TableColumn fx:id="addressCol" text="Address" prefWidth="100"/>
                  <TableColumn fx:id="cityCol" text="City" prefWidth="80"/>
                  <TableColumn fx:id="countryCol" text="Country" prefWidth="80"/>
                  <TableColumn fx:id="bedroomsCol" text="BR" prefWidth="40"/>
                  <TableColumn fx:id="bathroomsCol" text="BA" prefWidth="40"/>
                  <TableColumn fx:id="maxGuestsCol" text="Max" prefWidth="40"/>
                  <TableColumn fx:id="priceCol" text="Price" prefWidth="70"/>
                  <TableColumn fx:id="imagesCol" text="Images" prefWidth="80"/>
                  <TableColumn fx:id="isActiveCol" text="Active" prefWidth="60"/>
                  <TableColumn fx:id="actionsCol" text="Actions" prefWidth="100"/>
               </columns>
            </TableView>

            <ScrollPane fx:id="userScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="edge-to-edge">
               <content>
                  <FlowPane fx:id="userCardsContainer" hgap="25" vgap="25" prefWrapLength="1200">
                     <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                     </padding>
                  </FlowPane>
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </center>
</BorderPane>
