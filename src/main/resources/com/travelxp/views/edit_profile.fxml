<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<StackPane alignment="CENTER" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.travelxp.controllers.EditProfileController">
   <children>
      <VBox alignment="CENTER" maxWidth="500.0" spacing="20.0" styleClass="card">
         <children>
            <Label text="EDIT PROFILE" styleClass="title" />
            <VBox spacing="10.0">
               <children>
                  <Label text="Email" />
                  <TextField fx:id="emailField" promptText="Enter new email" />
               </children>
            </VBox>
            <VBox spacing="10.0">
               <children>
                  <Label text="Birthday" />
                  <DatePicker fx:id="birthdayPicker" maxWidth="Infinity" />
               </children>
            </VBox>
            <VBox spacing="10.0">
               <children>
                  <Label text="Bio" />
                  <TextArea fx:id="bioArea" prefHeight="100.0" promptText="Max 500 characters" />
               </children>
            </VBox>
            <HBox spacing="10.0" alignment="CENTER_LEFT">
               <children>
                  <Button onAction="#handleImageUpload" styleClass="secondary-button" text="Change Image" />
                  <Label fx:id="imagePathLabel" text="No image selected" />
               </children>
            </HBox>
            <HBox spacing="10.0" alignment="CENTER">
               <children>
                  <Button onAction="#handleUpdate" text="SAVE CHANGES" maxWidth="Infinity" HBox.hgrow="ALWAYS" />
                  <Button onAction="#handleCancel" styleClass="secondary-button" text="CANCEL" maxWidth="Infinity" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
         </padding>
      </VBox>
   </children>
</StackPane>
