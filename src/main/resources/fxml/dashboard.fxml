<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.travelxp.controller.DashboardController">
    <top>
        <VBox spacing="6">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10" />
            </padding>
            <Label fx:id="welcomeLabel" style="-fx-font-size: 22px; -fx-font-weight: bold;" />
            <HBox spacing="20">
                <Label fx:id="levelLabel" />
                <Label fx:id="xpLabel" />
            </HBox>
            <ProgressBar fx:id="xpProgressBar" prefWidth="400" />
            <HBox spacing="10">
                <Button fx:id="browseButton" text="Browse Properties" onAction="#handleBrowseProperties" />
                <Button fx:id="profileButton" text="Profile" onAction="#handleViewProfile" />
                <Button fx:id="logoutButton" text="Logout" onAction="#handleLogout" />
            </HBox>
        </VBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.4">
            <VBox spacing="10">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10" />
                </padding>
                <Label text="Achievements" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                <ScrollPane fitToWidth="true" prefHeight="400">
                    <content>
                        <VBox fx:id="achievementsBox" spacing="5" />
                    </content>
                </ScrollPane>
            </VBox>
            <VBox spacing="10">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10" />
                </padding>
                <Label text="Recent Bookings" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                <TableView fx:id="bookingsTable" prefHeight="400">
                    <columns>
                        <TableColumn fx:id="propertyColumn" text="Property" prefWidth="150" />
                        <TableColumn fx:id="datesColumn" text="Dates" prefWidth="200" />
                        <TableColumn fx:id="statusColumn" text="Status" prefWidth="100" />
                    </columns>
                </TableView>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
