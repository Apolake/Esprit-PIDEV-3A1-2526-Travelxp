                                    <Button text="Delete Comment" onAction="#handleCommentDelete" />
                                    <Button text="Reset" onAction="#handleCommentReset" />
                                </HBox>
                            </VBox>
                        </bottom>
                    </BorderPane>
                </Tab>
            </tabs>
        </TabPane>
    </center>
</BorderPane>
