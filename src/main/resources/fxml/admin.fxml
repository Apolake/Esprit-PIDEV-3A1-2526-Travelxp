                                        <Label text="Property" GridPane.rowIndex="0" GridPane.columnIndex="2" />
                                        <Label fx:id="reviewPropertyLabel" GridPane.rowIndex="0" GridPane.columnIndex="3" />

                                        <Label text="Reviewer" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                                        <Label fx:id="reviewUserLabel" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                                        <Label text="Rating" GridPane.rowIndex="1" GridPane.columnIndex="2" />
                                        <Spinner fx:id="reviewRatingSpinner" GridPane.rowIndex="1" GridPane.columnIndex="3" />

                                        <Label text="Comment" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                                        <TextArea fx:id="reviewCommentArea" prefRowCount="2" GridPane.rowIndex="2" GridPane.columnIndex="1" GridPane.columnSpan="3" />
                                    </children>
                                </GridPane>
                                <HBox spacing="8">
                                    <Button text="Create Review" onAction="#handleReviewCreate" />
                                    <Button text="Save Review" onAction="#handleReviewSave" />
                                    <Button text="Delete Review" onAction="#handleReviewDelete" />
                                    <Button text="Reset" onAction="#handleReviewReset" />
                                </HBox>
                            </VBox>
                        </bottom>
                    </BorderPane>
                </Tab>

                <Tab text="Comments">
                    <BorderPane>
                        <center>
                            <TableView fx:id="commentsTable" prefHeight="240">
                                <columns>
                                    <TableColumn fx:id="commentIdColumn" text="ID" prefWidth="60" />
                                    <TableColumn fx:id="commentReviewColumn" text="Review" prefWidth="120" />
                                    <TableColumn fx:id="commentUserColumn" text="User" prefWidth="140" />
                                    <TableColumn fx:id="commentSnippetColumn" text="Comment" prefWidth="220" />
                                    <TableColumn fx:id="commentCreatedColumn" text="Created" prefWidth="140" />
                                </columns>
                            </TableView>
                        </center>
                        <bottom>
                            <VBox spacing="8">
                                <padding>
                                    <Insets top="10" right="10" bottom="10" left="10" />
                                </padding>
                                <GridPane hgap="8" vgap="8">
                                    <columnConstraints>
                                        <ColumnConstraints minWidth="120" />
                                        <ColumnConstraints minWidth="220" />
                                        <ColumnConstraints minWidth="120" />
                                        <ColumnConstraints minWidth="220" />
                                    </columnConstraints>
                                    <children>
                                        <Label text="Review" GridPane.rowIndex="0" GridPane.columnIndex="0" />
