                                <GridPane hgap="8" vgap="8">
                                    <columnConstraints>
                                        <ColumnConstraints minWidth="120" />
                                        <ColumnConstraints minWidth="220" />
                                        <ColumnConstraints minWidth="120" />
                                        <ColumnConstraints minWidth="220" />
                                    </columnConstraints>
                                    <children>
                                        <Label text="Booking" GridPane.rowIndex="0" GridPane.columnIndex="0" />
