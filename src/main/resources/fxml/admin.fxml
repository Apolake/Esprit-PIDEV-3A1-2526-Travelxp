                                        <Label text="User" GridPane.rowIndex="0" GridPane.columnIndex="2" />
                                        <ComboBox fx:id="commentUserCombo" GridPane.rowIndex="0" GridPane.columnIndex="3" />

                                        <Label text="Comment" GridPane.rowIndex="1" GridPane.columnIndex="0" />
