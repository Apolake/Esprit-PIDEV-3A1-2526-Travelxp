                                    <TableColumn fx:id="reviewIdColumn" text="ID" prefWidth="60" />
                                    <TableColumn fx:id="reviewPropertyColumn" text="Property" prefWidth="150" />
                                    <TableColumn fx:id="reviewReviewerColumn" text="Reviewer" prefWidth="140" />
                                    <TableColumn fx:id="reviewRatingColumn" text="Rating" prefWidth="80" />
                                    <TableColumn fx:id="reviewCommentColumn" text="Comment" prefWidth="200" />
