<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.travelxp.controller.BookingController" spacing="12">
    <padding>
        <Insets top="15" right="15" bottom="15" left="15" />
    </padding>
    <Label fx:id="propertyLabel" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="120" />
            <ColumnConstraints minWidth="200" />
        </columnConstraints>
        <children>
            <Label text="Check-in" GridPane.rowIndex="0" GridPane.columnIndex="0" />
            <DatePicker fx:id="checkInPicker" GridPane.rowIndex="0" GridPane.columnIndex="1" />

            <Label text="Check-out" GridPane.rowIndex="1" GridPane.columnIndex="0" />
            <DatePicker fx:id="checkOutPicker" GridPane.rowIndex="1" GridPane.columnIndex="1" />

            <Label text="Guests" GridPane.rowIndex="2" GridPane.columnIndex="0" />
            <Spinner fx:id="guestsSpinner" GridPane.rowIndex="2" GridPane.columnIndex="1" />

            <Label text="Special Requests" GridPane.rowIndex="3" GridPane.columnIndex="0" />
            <TextArea fx:id="specialRequestsArea" prefRowCount="3" GridPane.rowIndex="3" GridPane.columnIndex="1" />
        </children>
    </GridPane>

    <Label fx:id="totalPriceLabel" text="Total: $0.00" style="-fx-font-size: 16px; -fx-font-weight: bold;" />

    <HBox spacing="10">
        <Button fx:id="confirmButton" text="Confirm Booking" onAction="#handleConfirmBooking" />
        <Button text="Cancel" onAction="#handleCancel" />
    </HBox>
</VBox>
