<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.travelxp.controller.PropertyDetailController" spacing="10">
    <padding>
        <Insets top="15" right="15" bottom="15" left="15" />
    </padding>
    <Label fx:id="titleLabel" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
    <Label fx:id="locationLabel" />
    <Label fx:id="priceLabel" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
    <Label fx:id="detailsLabel" />
    <TextArea fx:id="descriptionArea" editable="false" wrapText="true" prefRowCount="4" />
    <Label fx:id="amenitiesLabel" />

    <Label text="Reviews" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
    <ScrollPane fitToWidth="true" prefHeight="200">
        <content>
            <VBox fx:id="reviewsBox" spacing="8" />
        </content>
    </ScrollPane>

    <HBox spacing="10">
        <Button fx:id="bookButton" text="Book Now" onAction="#handleBookNow" />
        <Button text="Back" onAction="#handleBack" />
    </HBox>
</VBox>
