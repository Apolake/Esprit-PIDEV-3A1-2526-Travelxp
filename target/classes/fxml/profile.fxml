<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.travelxp.controller.ProfileController" spacing="12">
    <padding>
        <Insets top="15" right="15" bottom="15" left="15" />
    </padding>
    <Label text="Profile" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
    <Label fx:id="usernameLabel" style="-fx-font-size: 16px;" />
    <Label fx:id="emailLabel" />
    <Label fx:id="levelLabel" />
    <Label fx:id="xpLabel" />
    <ProgressBar fx:id="levelProgressBar" prefWidth="300" />

    <Label text="Bio" style="-fx-font-weight: bold;" />
    <TextArea fx:id="bioArea" prefRowCount="4" wrapText="true" />
    <Button text="Update Bio" onAction="#handleUpdateBio" />

    <Label text="Achievements" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
    <ScrollPane fitToWidth="true" prefHeight="200">
        <content>
            <VBox fx:id="achievementsBox" spacing="8" />
        </content>
    </ScrollPane>

    <Button text="Back" onAction="#handleBack" />
</VBox>
