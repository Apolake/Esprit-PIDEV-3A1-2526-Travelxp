<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<StackPane alignment="CENTER" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.travelxp.controllers.ChangePasswordController">
   <children>
      <VBox alignment="CENTER" maxWidth="400.0" spacing="20.0" styleClass="card">
         <children>
            <Label text="CHANGE PASSWORD" styleClass="title" />
            <VBox spacing="10.0">
               <children>
                  <Label text="Current Password" />
                  <PasswordField fx:id="currentPasswordField" promptText="Enter current password" />
               </children>
            </VBox>
            <VBox spacing="10.0">
               <children>
                  <Label text="New Password" />
                  <PasswordField fx:id="newPasswordField" promptText="8+ chars, 1 letter, 1 number" />
               </children>
            </VBox>
            <VBox spacing="10.0">
               <children>
                  <Label text="Confirm New Password" />
                  <PasswordField fx:id="confirmNewPasswordField" promptText="Repeat new password" />
               </children>
            </VBox>
            <HBox spacing="10.0" alignment="CENTER">
               <children>
                  <Button onAction="#handleChangePassword" text="CHANGE PASSWORD" maxWidth="Infinity" HBox.hgrow="ALWAYS" />
                  <Button onAction="#handleCancel" styleClass="secondary-button" text="CANCEL" maxWidth="Infinity" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
         </padding>
      </VBox>
   </children>
</StackPane>
