<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<StackPane alignment="CENTER" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.travelxp.controllers.ChangePasswordController" styleClass="root">
   <children>
      <VBox alignment="CENTER" maxWidth="450.0" spacing="35.0" styleClass="card">
         <children>
            <VBox spacing="10">
               <children>
                  <Label text="Change Password" styleClass="title" style="-fx-font-size: 32px;" />
                  <Label text="Update your account security." styleClass="header-text" />
               </children>
            </VBox>
            
            <VBox spacing="20.0">
               <children>
                  <VBox spacing="8.0">
                     <children>
                        <Label text="Current Password" style="-fx-font-weight: bold; -fx-text-fill: -fx-text-muted;" />
                        <PasswordField fx:id="currentPasswordField" promptText="Enter current password" />
                     </children>
                  </VBox>
                  <VBox spacing="8.0">
                     <children>
                        <Label text="New Password" style="-fx-font-weight: bold; -fx-text-fill: -fx-text-muted;" />
                        <PasswordField fx:id="newPasswordField" promptText="8+ chars, 1 letter, 1 number" />
                     </children>
                  </VBox>
                  <VBox spacing="8.0">
                     <children>
                        <Label text="Confirm New Password" style="-fx-font-weight: bold; -fx-text-fill: -fx-text-muted;" />
                        <PasswordField fx:id="confirmNewPasswordField" promptText="Repeat new password" />
                     </children>
                  </VBox>
               </children>
            </VBox>
            
            <HBox spacing="20.0" alignment="CENTER">
               <children>
                  <Button onAction="#handleChangePassword" text="Save Changes" maxWidth="Infinity" HBox.hgrow="ALWAYS" />
                  <Button onAction="#handleCancel" styleClass="secondary-button" text="Cancel" maxWidth="Infinity" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="60.0" left="60.0" right="60.0" top="60.0" />
         </padding>
      </VBox>
      <Button onAction="#toggleTheme" text="🌙 / ☀️" styleClass="secondary-button" StackPane.alignment="TOP_RIGHT">
         <StackPane.margin>
            <Insets top="20" right="20" />
         </StackPane.margin>
      </Button>
   </children>
</StackPane>
