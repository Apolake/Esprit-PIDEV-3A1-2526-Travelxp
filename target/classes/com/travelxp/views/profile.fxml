<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<StackPane alignment="CENTER" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.travelxp.controllers.ProfileController" styleClass="root">
   <children>
      <VBox alignment="CENTER" maxWidth="600.0" spacing="20.0" styleClass="card">
         <children>
            <Label text="PROFILE" styleClass="title-1" />
            <ImageView fx:id="profileImageView" fitHeight="150.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true" />
            <VBox spacing="5.0" alignment="CENTER">
               <children>
                  <Label text="Username" styleClass="text-caption" />
                  <Label fx:id="usernameLabel" text="UsernameValue" styleClass="title-4" />
               </children>
            </VBox>
            <VBox spacing="5.0" alignment="CENTER">
               <children>
                  <Label text="Email" styleClass="text-caption" />
                  <Label fx:id="emailLabel" text="EmailValue" />
               </children>
            </VBox>
            <VBox spacing="5.0" alignment="CENTER">
               <children>
                  <Label text="Birthday" styleClass="text-caption" />
                  <Label fx:id="birthdayLabel" text="BirthdayValue" />
               </children>
            </VBox>
            <VBox spacing="5.0" alignment="CENTER">
               <children>
                  <Label text="Bio" styleClass="text-caption" />
                  <Label fx:id="bioLabel" text="BioValue" wrapText="true" maxWidth="400.0" />
               </children>
            </VBox>
            <VBox spacing="5.0" alignment="CENTER">
               <children>
                  <Label text="Member Since" styleClass="text-caption" />
                  <Label fx:id="joinedLabel" text="JoinedValue" />
               </children>
            </VBox>
            <HBox spacing="10.0" alignment="CENTER">
               <children>
                  <Button onAction="#handleEditProfile" text="EDIT PROFILE" styleClass="accent" />
                  <Button onAction="#handleChangePassword" text="CHANGE PASSWORD" styleClass="flat" />
               </children>
            </HBox>
            <HBox spacing="10.0" alignment="CENTER">
               <children>
                  <Button onAction="#handleDeleteAccount" styleClass="danger" text="DELETE ACCOUNT" />
                  <Button onAction="#handleLogout" styleClass="flat" text="LOGOUT" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
         </padding>
      </VBox>
   </children>
</StackPane>
