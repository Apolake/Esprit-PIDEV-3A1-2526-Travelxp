<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.travelxp.controllers.GeminiChatController" styleClass="root">
   <left>
      <VBox styleClass="sidebar" prefWidth="280">
         <children>
            <VBox alignment="CENTER" spacing="10">
               <padding>
                  <Insets top="40" bottom="40"/>
               </padding>
               <children>
                  <Label text="TRAVELXP" styleClass="title-1" />
                  <Separator />
               </children>
            </VBox>
            
            <VBox spacing="5" VBox.vgrow="ALWAYS">
               <children>
                  <Button onAction="#handleDashboard" maxWidth="Infinity" styleClass="nav-button, flat" text="Dashboard">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-home-page-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button onAction="#handleTasks" maxWidth="Infinity" styleClass="nav-button, flat" text="Tasks">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-to-do-list-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button onAction="#handleBrowseProperties" maxWidth="Infinity" styleClass="nav-button, flat" text="Browse Properties">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-home-page-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button onAction="#handleBrowseTrips" maxWidth="Infinity" styleClass="nav-button, flat" text="Browse Trips">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-advance-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button onAction="#handleMyBookings" maxWidth="Infinity" styleClass="nav-button, flat" text="My Bookings">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-done-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button onAction="#handleMyTrips" maxWidth="Infinity" styleClass="nav-button, flat" text="My Trips">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-advance-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button onAction="#handleEditProfile" maxWidth="Infinity" styleClass="nav-button, flat" text="Edit Profile">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-pencil-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button onAction="#handleChangePassword" maxWidth="Infinity" styleClass="nav-button, flat" text="Security">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-services-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button onAction="#handleFeedback" maxWidth="Infinity" styleClass="nav-button, flat" text="Feedback">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-to-do-list-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button maxWidth="Infinity" styleClass="nav-button, accent" text="AI Assistant">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-services-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
               </children>
            </VBox>
            
            <VBox spacing="10" alignment="BOTTOM_CENTER">
               <padding>
                  <Insets bottom="30" left="20" right="20"/>
               </padding>
               <children>
                  <Button onAction="#handleLogout" maxWidth="Infinity" styleClass="danger, flat" text="Logout">
                     <graphic>
                        <ImageView fitHeight="16" fitWidth="16">
                           <image>
                              <Image url="@../../../icons/icons8-advance-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
               </children>
            </VBox>
         </children>
      </VBox>
   </left>
   
   <center>
      <StackPane styleClass="center-bg">
         <children>
            <Pane fx:id="animatedBg" styleClass="animated-bg" />
            
            <VBox spacing="0" StackPane.alignment="CENTER">
               <padding>
                  <Insets top="30" right="60" bottom="30" left="60"/>
               </padding>
               <children>
                  <!-- Header -->
                  <VBox spacing="5">
                     <padding>
                        <Insets bottom="20"/>
                     </padding>
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="15">
                           <children>
                              <Label text="TravelXP AI Assistant" styleClass="title-1" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Button onAction="#handleClearChat" styleClass="flat" text="New Chat" />
                           </children>
                        </HBox>
                        <Label text="Ask me anything about TravelXP — I know every feature and can help you navigate the app." styleClass="text-muted" />
                     </children>
                  </VBox>
                  
                  <!-- Chat Messages Area -->
                  <ScrollPane fx:id="chatScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" 
                              styleClass="edge-to-edge" hbarPolicy="NEVER">
                     <content>
                        <VBox fx:id="chatContainer" spacing="15">
                           <padding>
                              <Insets top="10" right="10" bottom="10" left="10"/>
                           </padding>
                        </VBox>
                     </content>
                  </ScrollPane>
                  
                  <!-- Input Area -->
                  <HBox spacing="12" alignment="CENTER_LEFT">
                     <padding>
                        <Insets top="20"/>
                     </padding>
                     <children>
                        <TextField fx:id="messageField" promptText="Type your question here..." 
                                   HBox.hgrow="ALWAYS" onAction="#handleSend"
                                   style="-fx-font-size: 14px; -fx-padding: 12 16; -fx-background-radius: 24;" />
                        <Button fx:id="sendButton" onAction="#handleSend" styleClass="accent" 
                                text="Send" style="-fx-font-size: 14px; -fx-padding: 12 24; -fx-background-radius: 24;" />
                     </children>
                  </HBox>
               </children>
            </VBox>
            
            <Button onAction="#toggleTheme" styleClass="theme-toggle-button" StackPane.alignment="TOP_RIGHT">
               <graphic>
                  <Region styleClass="theme-icon" />
               </graphic>
               <StackPane.margin>
                  <Insets top="20" right="20" />
               </StackPane.margin>
            </Button>
         </children>
      </StackPane>
   </center>
</BorderPane>
