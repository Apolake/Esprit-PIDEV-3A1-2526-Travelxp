<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.travelxp.controllers.TasksController" styleClass="root">
   <left>
      <VBox styleClass="sidebar" prefWidth="280">
         <children>
            <VBox alignment="CENTER" spacing="10">
               <padding>
                  <Insets top="40" bottom="40"/>
               </padding>
               <children>
                  <Label text="TRAVELXP" styleClass="sidebar-title" />
                  <Line endX="100" styleClass="sidebar-divider" strokeWidth="1"/>
               </children>
            </VBox>
            
            <VBox spacing="5" VBox.vgrow="ALWAYS">
               <children>
                  <Button onAction="#handleDashboard" maxWidth="Infinity" styleClass="nav-button" text="Dashboard">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-home-page-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button maxWidth="Infinity" styleClass="nav-button, nav-button-active" text="Tasks">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-to-do-list-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button onAction="#handleEditProfile" maxWidth="Infinity" styleClass="nav-button" text="Edit Profile">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-pencil-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button onAction="#handleChangePassword" maxWidth="Infinity" styleClass="nav-button" text="Security">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-services-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
               </children>
            </VBox>
            
            <VBox spacing="10" alignment="BOTTOM_CENTER">
               <padding>
                  <Insets bottom="30" left="20" right="20"/>
               </padding>
               <children>
                  <Button onAction="#handleLogout" maxWidth="Infinity" styleClass="secondary-button" text="Logout" style="-fx-text-fill: #CF6679; -fx-border-color: #CF6679;">
                     <graphic>
                        <ImageView fitHeight="16" fitWidth="16">
                           <image>
                              <Image url="@../../../icons/icons8-advance-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
               </children>
            </VBox>
         </children>
      </VBox>
   </left>
   
   <center>
      <StackPane styleClass="center-bg">
         <children>
            <ScrollPane fitToWidth="true" styleClass="scroll-pane">
               <content>
                  <VBox spacing="40">
                     <padding>
                        <Insets top="50" right="60" bottom="50" left="60"/>
                     </padding>
                     <children>
                        <VBox spacing="5">
                           <children>
                              <Label styleClass="title" text="XP Quests" />
                              <Label text="Complete tasks to earn experience points and level up!" styleClass="header-text" />
                           </children>
                        </VBox>
                        
                        <VBox spacing="20">
                           <children>
                              <HBox alignment="CENTER_LEFT" styleClass="task-item">
                                 <children>
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                       <children>
                                          <Label text="Daily Login" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                                          <Label text="Log in every day to maintain your streak." style="-fx-text-fill: -fx-text-muted;" />
                                       </children>
                                    </VBox>
                                    <Label text="+10 XP" styleClass="xp-badge" />
                                 </children>
                              </HBox>
                              
                              <HBox alignment="CENTER_LEFT" styleClass="task-item">
                                 <children>
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                       <children>
                                          <Label text="Profile Completion" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                                          <Label text="Update your bio, birthday, or profile image." style="-fx-text-fill: -fx-text-muted;" />
                                       </children>
                                    </VBox>
                                    <Label text="+5 XP" styleClass="xp-badge" />
                                 </children>
                              </HBox>
                              
                              <HBox alignment="CENTER_LEFT" styleClass="task-item">
                                 <children>
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                       <children>
                                          <Label text="Security Boost" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                                          <Label text="Update your password or email to keep your account safe." style="-fx-text-fill: -fx-text-muted;" />
                                       </children>
                                    </VBox>
                                    <Label text="+5 XP" styleClass="xp-badge" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </children>
                  </VBox>
               </content>
            </ScrollPane>
            <Button onAction="#toggleTheme" styleClass="theme-toggle-button" StackPane.alignment="TOP_RIGHT">
               <graphic>
                  <Region styleClass="theme-icon" />
               </graphic>
               <StackPane.margin>
                  <Insets top="20" right="20" />
               </StackPane.margin>
            </Button>
         </children>
      </StackPane>
   </center>
</BorderPane>
