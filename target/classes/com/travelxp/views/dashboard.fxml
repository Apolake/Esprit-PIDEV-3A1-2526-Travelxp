<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.travelxp.controllers.DashboardController" styleClass="root">
   <left>
      <VBox styleClass="sidebar" prefWidth="280">
         <children>
            <VBox alignment="CENTER" spacing="10">
               <padding>
                  <Insets top="40" bottom="40"/>
               </padding>
               <children>
                  <Label text="TRAVELXP" styleClass="sidebar-title" />
                  <Line endX="100" styleClass="sidebar-divider" strokeWidth="1"/>
               </children>
            </VBox>
            
            <VBox spacing="5" VBox.vgrow="ALWAYS">
               <children>
                  <Button maxWidth="Infinity" styleClass="nav-button, nav-button-active" text="Dashboard">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-home-page-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button onAction="#handleTasks" maxWidth="Infinity" styleClass="nav-button" text="Tasks">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-to-do-list-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button onAction="#handleEditProfile" maxWidth="Infinity" styleClass="nav-button" text="Edit Profile">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-pencil-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button onAction="#handleChangePassword" maxWidth="Infinity" styleClass="nav-button" text="Security">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-services-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
               </children>
            </VBox>
            
            <VBox spacing="10" alignment="BOTTOM_CENTER">
               <padding>
                  <Insets bottom="30" left="20" right="20"/>
               </padding>
               <children>
                  <Button onAction="#handleLogout" maxWidth="Infinity" styleClass="secondary-button" text="Logout" style="-fx-text-fill: #CF6679; -fx-border-color: #CF6679;">
                     <graphic>
                        <ImageView fitHeight="16" fitWidth="16">
                           <image>
                              <Image url="@../../../icons/icons8-advance-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
               </children>
            </VBox>
         </children>
      </VBox>
   </left>
   
   <center>
      <StackPane styleClass="center-bg">
         <children>
            <ScrollPane fitToWidth="true" styleClass="scroll-pane">
               <content>
                  <VBox spacing="40">
                     <padding>
                        <Insets top="50" right="60" bottom="50" left="60"/>
                     </padding>
                     <children>
                        <VBox spacing="5">
                           <children>
                              <Label fx:id="welcomeLabel" styleClass="title" text="Hello, User!" />
                              <Label text="Here is your travel summary and achievements." styleClass="header-text" />
                           </children>
                        </VBox>
                        
                        <FlowPane hgap="30" vgap="30" alignment="TOP_LEFT">
                           <children>
                              <!-- Profile Card -->
                              <VBox spacing="25" styleClass="card" prefWidth="550">
                                 <children>
                                    <Label text="Profile Overview" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: -fx-accent;" />
                                    <HBox spacing="30" alignment="CENTER_LEFT">
                                       <children>
                                          <StackPane style="-fx-background-color: -fx-field-bg; -fx-background-radius: 50%; -fx-padding: 5;">
                                             <children>
                                                <ImageView fx:id="profileImageView" fitHeight="120" fitWidth="120" pickOnBounds="true" preserveRatio="true" />
                                             </children>
                                          </StackPane>
                                          <VBox spacing="12">
                                             <children>
                                                <Label fx:id="emailLabel" text="email@example.com" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                                                <HBox spacing="10" alignment="CENTER_LEFT">
                                                   <children>
                                                      <Label text="Birthday:" style="-fx-text-fill: -fx-text-muted;" />
                                                      <Label fx:id="birthdayLabel" text="Jan 1, 1990" />
                                                   </children>
                                                </HBox>
                                                <VBox spacing="5">
                                                   <children>
                                                      <Label text="Bio" style="-fx-text-fill: -fx-text-muted;" />
                                                      <Label fx:id="bioLabel" text="No bio provided yet." wrapText="true" maxWidth="350" style="-fx-line-spacing: 5;" />
                                                   </children>
                                                </VBox>
                                             </children>
                                          </VBox>
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>
                              
                              <!-- Gamification Card -->
                              <VBox spacing="25" styleClass="card" prefWidth="550">
                                 <children>
                                    <HBox alignment="CENTER_LEFT">
                                       <children>
                                          <Label text="Travel Rank" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: -fx-accent;" />
                                          <Region HBox.hgrow="ALWAYS" />
                                          <Label fx:id="titleLabel" styleClass="title-badge" text="Novice" />
                                       </children>
                                    </HBox>
                                    
                                    <HBox spacing="35" alignment="CENTER">
                                       <children>
                                          <VBox alignment="CENTER" styleClass="level-badge">
                                             <children>
                                                <Label text="LVL" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" />
                                                <Label fx:id="levelLabel" styleClass="level-text" text="1" />
                                             </children>
                                          </VBox>
                                          
                                          <VBox spacing="15" HBox.hgrow="ALWAYS">
                                             <children>
                                                <HBox alignment="BOTTOM_LEFT">
                                                   <children>
                                                      <Label text="Experience Points" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                                                      <Region HBox.hgrow="ALWAYS" />
                                                      <Label fx:id="xpLabel" text="450 / 1000" style="-fx-text-fill: -fx-accent; -fx-font-weight: bold;" />
                                                   </children>
                                                </HBox>
                                                <ProgressBar fx:id="xpProgressBar" progress="0.45" maxWidth="Infinity" />
                                                <Label text="Earn XP by updating your profile and being active!" style="-fx-text-fill: -fx-text-muted; -fx-font-size: 12px;" />
                                             </children>
                                          </VBox>
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>
                           </children>
                        </FlowPane>
                     </children>
                  </VBox>
               </content>
            </ScrollPane>
            <Button onAction="#toggleTheme" styleClass="theme-toggle-button" StackPane.alignment="TOP_RIGHT">
               <graphic>
                  <Region styleClass="theme-icon" />
               </graphic>
               <StackPane.margin>
                  <Insets top="20" right="20" />
               </StackPane.margin>
            </Button>
         </children>
      </StackPane>
   </center>
</BorderPane>
