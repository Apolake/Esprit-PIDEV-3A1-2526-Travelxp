<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.travelxp.controllers.MessengerController" 
            prefWidth="1000" prefHeight="750" style="-fx-background-color: #f8f9fa;">

    <!-- Header with gradient background -->
    <VBox style="-fx-background-color: linear-gradient(to right, #667eea 0%, #764ba2 100%); -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 2);" BorderPane.alignment="TOP">
        <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-padding: 20; -fx-background-color: transparent;">
            <StackPane>
                <Circle radius="30" fill="#ffffff" opacity="0.2"/>
                <Circle radius="25" fill="#ffffff" opacity="0.3"/>
                <Text fx:id="userInitials" text="U" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-fill: white;"/>
            </StackPane>
            
            <VBox spacing="4">
                <Label fx:id="conversationTitle" text="Conversation" style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;"/>
                <Label fx:id="onlineStatus" text="Online" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12;"/>
            </VBox>
            
            <Region HBox.hgrow="ALWAYS"/>
            
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 8 16;">
                    <graphic>
                        <Label text="📞" style="-fx-font-size: 14;"/>
                    </graphic>
                </Button>
                <Button style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 8 16;">
                    <graphic>
                        <Label text="📹" style="-fx-font-size: 14;"/>
                    </graphic>
                </Button>
                <Button fx:id="closeButton" text="✕" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 8 12; -fx-font-size: 14;"/>
            </HBox>
        </HBox>
    </VBox>

    <!-- Main content area -->
    <VBox spacing="0" style="-fx-background-color: white;" BorderPane.alignment="CENTER">
        
        <!-- Messages area with modern card layout -->
        <ScrollPane fx:id="messagesScrollPane" fitToWidth="true" style="-fx-background: white; -fx-border: none;">
            <VBox fx:id="messagesContainer" spacing="16" style="-fx-padding: 24; -fx-background-color: white;">
                <!-- Messages will be added here dynamically -->
            </VBox>
        </ScrollPane>

        <!-- Divider -->
        <Separator style="-fx-background-color: #e9ecef;"/>

        <!-- Input area with floating design -->
        <VBox spacing="12" style="-fx-padding: 20; -fx-background-color: #ffffff; -fx-border-top: 1px solid #e9ecef;">
            <HBox spacing="12" alignment="CENTER">
                <Button style="-fx-background-color: #667eea; -fx-text-fill: white; -fx-border-radius: 50; -fx-background-radius: 50; -fx-min-width: 40; -fx-min-height: 40;">
                    <graphic>
                        <Label text="😊" style="-fx-font-size: 16;"/>
                    </graphic>
                </Button>
                
                <Button style="-fx-background-color: #764ba2; -fx-text-fill: white; -fx-border-radius: 50; -fx-background-radius: 50; -fx-min-width: 40; -fx-min-height: 40;">
                    <graphic>
                        <Label text="📎" style="-fx-font-size: 16;"/>
                    </graphic>
                </Button>
                
                <TextArea fx:id="messageInput" wrapText="true" prefRowCount="2" minHeight="60" maxHeight="120" 
                         promptText="Type your message here..." 
                         style="-fx-font-size: 14; -fx-padding: 12; -fx-border-radius: 20; -fx-background-radius: 20; -fx-border-color: #e9ecef; -fx-background-color: #f8f9fa; -fx-border-width: 1;">
                    <HBox.margin>
                        <Insets left="10" right="10"/>
                    </HBox.margin>
                </TextArea>
                
                <Button fx:id="sendButton" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-border-radius: 50; -fx-background-radius: 50; -fx-min-width: 50; -fx-min-height: 50;">
                    <graphic>
                        <Label text="📤" style="-fx-font-size: 18;"/>
                    </graphic>
                </Button>
            </HBox>
            
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Label fx:id="typingIndicator" text="" style="-fx-text-fill: #6c757d; -fx-font-size: 12; -fx-font-style: italic;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="messageCount" text="0 messages" style="-fx-text-fill: #6c757d; -fx-font-size: 11;"/>
            </HBox>
        </VBox>
    </VBox>

    <!-- Floating action button for quick actions -->
    <StackPane style="-fx-background-color: transparent;" BorderPane.alignment="BOTTOM_RIGHT">
        <Button fx:id="floatingActionButton" style="-fx-background-color: #667eea; -fx-text-fill: white; -fx-border-radius: 50; -fx-background-radius: 50; -fx-min-width: 60; -fx-min-height: 60; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 2);">
            <graphic>
                <Label text="➕" style="-fx-font-size: 20;"/>
            </graphic>
            <StackPane.margin>
                <Insets bottom="20" right="20"/>
            </StackPane.margin>
        </Button>
    </StackPane>

    <!-- Bottom info bar -->
    <HBox spacing="20" alignment="CENTER" style="-fx-background-color: #f8f9fa; -fx-border-top: 1px solid #e9ecef; -fx-padding: 10;" BorderPane.alignment="BOTTOM">
        <Label style="-fx-text-fill: #6c757d; -fx-font-size: 11;">
            💡 Tip: Use @username to mention someone in your message
        </Label>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lastSeen" text="Last seen: Just now" style="-fx-text-fill: #6c757d; -fx-font-size: 11;"/>
    </HBox>

</BorderPane>