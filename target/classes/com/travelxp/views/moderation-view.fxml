<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.travelxp.controllers.ModerationController" stylesheets="@../../../style.css" styleClass="root">
   <left>
      <VBox styleClass="sidebar" prefWidth="280">
         <children>
            <VBox alignment="CENTER" spacing="10">
               <padding>
                  <Insets top="40" bottom="40"/>
               </padding>
               <children>
                  <Label text="ADMIN PANEL" styleClass="title-2" />
                  <Separator />
               </children>
            </VBox>
            
            <VBox spacing="5" VBox.vgrow="ALWAYS">
               <children>
                  <Button onAction="#handleBack" maxWidth="Infinity" styleClass="nav-button, flat" text="Users">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-menu-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button onAction="#handleManageProperties" maxWidth="Infinity" styleClass="nav-button, flat" text="Properties">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-home-page-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button onAction="#handleManageOffers" maxWidth="Infinity" styleClass="nav-button, flat" text="Offers">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-favorite-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button onAction="#handleManageBookings" maxWidth="Infinity" styleClass="nav-button, flat" text="Bookings">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-done-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button onAction="#handleManageTrips" maxWidth="Infinity" styleClass="nav-button, flat" text="Trips">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-advance-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button onAction="#handleActivities" maxWidth="Infinity" styleClass="nav-button, flat" text="Activities">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-services-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button onAction="#handleManageTrips" maxWidth="Infinity" styleClass="nav-button, flat" text="Trips">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-advance-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button onAction="#handleActivities" maxWidth="Infinity" styleClass="nav-button, flat" text="Activities">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-services-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button maxWidth="Infinity" styleClass="nav-button, accent" text="Comments">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-pencil-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button onAction="#handleManageServices" maxWidth="Infinity" styleClass="nav-button, flat" text="Services">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                           <image>
                              <Image url="@../../../icons/icons8-services-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
               </children>
            </VBox>
            
            <VBox spacing="10" alignment="BOTTOM_CENTER">
               <padding>
                  <Insets bottom="30" left="20" right="20"/>
               </padding>
               <children>
                  <Button onAction="#handleLogout" maxWidth="Infinity" styleClass="danger, flat" text="Logout">
                     <graphic>
                        <ImageView fitHeight="16" fitWidth="16">
                           <image>
                              <Image url="@../../../icons/icons8-advance-50.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
               </children>
            </VBox>
         </children>
      </VBox>
   </left>

   <center>
      <StackPane styleClass="center-bg">
         <children>
            <Pane fx:id="animatedBg" styleClass="animated-bg" visible="false" />
            <VBox spacing="30">
               <padding>
                  <Insets top="20" right="20" bottom="20" left="20"/>
               </padding>
               <children>
                  <HBox spacing="20" alignment="CENTER_LEFT" styleClass="top-bar">
                     <children>
                        <Label text="Moderation Center" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                     </children>
                  </HBox>

                  <VBox spacing="10" VBox.vgrow="ALWAYS">
                     <children>
                        <Label text="All Feedback" styleClass="title-3"/>
                        <TableView fx:id="feedbackTable" VBox.vgrow="ALWAYS">
                           <columns>
                              <TableColumn fx:id="fIdCol" text="ID" prefWidth="50"/>
                              <TableColumn fx:id="fUserIdCol" text="User ID" prefWidth="60"/>
                              <TableColumn fx:id="fContentCol" text="Content" prefWidth="300"/>
                              <TableColumn fx:id="fDateCol" text="Date" prefWidth="150"/>
                              <TableColumn fx:id="fActionsCol" text="Actions" prefWidth="150"/>
                           </columns>
                        </TableView>
                     </children>
                  </VBox>
                  
                  <VBox spacing="10" VBox.vgrow="ALWAYS">
                     <children>
                        <Label text="All Comments" styleClass="title-3"/>
                        <TableView fx:id="commentTable" VBox.vgrow="ALWAYS">
                           <columns>
                              <TableColumn fx:id="cIdCol" text="ID" prefWidth="50"/>
                              <TableColumn fx:id="cFeedbackIdCol" text="Feed ID" prefWidth="60"/>
                              <TableColumn fx:id="cUserIdCol" text="User ID" prefWidth="60"/>
                              <TableColumn fx:id="cContentCol" text="Comment" prefWidth="300"/>
                              <TableColumn fx:id="cDateCol" text="Date" prefWidth="150"/>
                              <TableColumn fx:id="cActionsCol" text="Actions" prefWidth="150"/>
                           </columns>
                        </TableView>
                     </children>
                  </VBox>
               </children>
            </VBox>
            <Button onAction="#toggleTheme" styleClass="theme-toggle-button" StackPane.alignment="TOP_RIGHT">
               <graphic>
                  <Region styleClass="theme-icon" />
               </graphic>
               <StackPane.margin>
                  <Insets top="20" right="20" />
               </StackPane.margin>
            </Button>
         </children>
      </StackPane>
   </center>
</BorderPane>
